+    .reset = subghz_protocol_decoder_fiat_marelli_reset,
+    .get_hash_data = subghz_protocol_decoder_fiat_marelli_get_hash_data,
+    .serialize = subghz_protocol_decoder_fiat_marelli_serialize,
