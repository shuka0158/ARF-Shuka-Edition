+    block[1] = (uint8_t)(instance->serial >> 16);
+    block[2] = (uint8_t)(instance->serial >> 8);
+    block[3] = (uint8_t)(instance->serial);
+
+    block[4] = (uint8_t)(instance->cnt);
+    block[5] = (uint8_t)(instance->cnt >> 8);
+    block[6] = (uint8_t)(instance->cnt >> 16);
+
+    block[7] = btn_byte;
+
