+    uint64_t yek;
+    uint8_t crc;
+};
+
+struct SubGhzProtocolEncoderKiaV5 {
+    SubGhzProtocolEncoderBase base;
+    SubGhzProtocolBlockEncoder encoder;
+    SubGhzBlockGeneric generic;
+};
+
