+typedef enum {
+    FiatMarelliDecoderStepReset = 0,
+    FiatMarelliDecoderStepPreamble = 1,
+    FiatMarelliDecoderStepSync = 2,
+    FiatMarelliDecoderStepData = 3,
+    FiatMarelliDecoderStepRetxSync = 4,
+} FiatMarelliDecoderStep;
